{
  "Version": "2012-10-17",
  "Statement":
    [
      {
        "Effect": "Allow",
        "Action": [
        "s3:ListBucket",
        "s3:ListBucketVersions"
        ],
        "Resource": "arn:aws:s3:::divbase-local-*"
      },
      {
        "Effect": "Allow",
        "Action":
          [
            "s3:DeleteObject",
            "s3:DeleteObjectVersion"
          ],
        "Resource": "arn:aws:s3:::divbase-local-*/*"
      }
    ]
}
